# Next.js
NEXT_PUBLIC_SITE_URL=https://latinagrill.pt

# Resend — envio de emails de reserva
# Cria a conta em https://resend.com e copia a API key
RESEND_API_KEY=

# Reservation moderation — chave secreta usada para assinar os links de
# admin/cliente que vão por email. Gera com:
#   openssl rand -hex 64
# Mínimo 32 caracteres. Deve estar definida em Production e Preview na Vercel.
RESERVATION_TOKEN_SECRET=

# Analytics (opcional)
# NEXT_PUBLIC_GA_ID=
