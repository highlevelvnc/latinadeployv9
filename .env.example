# Next.js
NEXT_PUBLIC_SITE_URL=https://latinagrill.pt

# Resend — envio de emails de reserva
# Cria a conta em https://resend.com e copia a API key
RESEND_API_KEY=

# Reservation moderation — chave secreta usada para assinar os links de
# admin/cliente que vão por email. Gera com:
#   openssl rand -hex 64
# Mínimo 32 caracteres. Deve estar definida em Production e Preview na Vercel.
RESERVATION_TOKEN_SECRET=

# Cron secret — Vercel Cron envia "Authorization: Bearer $CRON_SECRET" e o
# endpoint /api/cron/daily só responde se bater. Gera com:
#   openssl rand -hex 32
CRON_SECRET=

# Vercel KV (Redis) — preenchidas automaticamente pela Vercel quando
# associas um KV database ao projeto. NÃO copiar para .env.local manualmente.
#   vercel env pull .env.local
# KV_URL=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# KV_REST_API_READ_ONLY_TOKEN=

# Twilio — SMS de confirmação / lembrete D-1 (custos ~€0.04 por SMS PT)
# Cria conta em https://www.twilio.com → Console mostra Account SID + Auth Token.
# Para mensagens com nome "LatinaGrill" (sem comprar número Twilio):
#   Painel → Messaging → Services → Create Messaging Service → name "LatinaGrill SMS"
#   → Sender Pool → Add Senders → Alphanumeric → "LatinaGrill"
#   → copia o "MG..." Service SID para TWILIO_MESSAGING_SERVICE_SID
# Se TWILIO_MESSAGING_SERVICE_SID estiver definido, é usado preferencialmente.
# Caso contrário cai para TWILIO_FROM (envio direto, formato legacy).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM=LatinaGrill

# Analytics (opcional)
# NEXT_PUBLIC_GA_ID=
